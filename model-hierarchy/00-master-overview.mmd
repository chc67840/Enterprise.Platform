  EntityDataState -.->|"normalised&nbsp;store"| BaseEntity
  ChromeConfig --> NavbarConfig
  ChromeConfig --> FooterConfig
  RouteMetadata -.->|"PageHeader&nbsp;default"| SubNav
  Forms -.->|"emits&nbsp;values"| ApiResponse
