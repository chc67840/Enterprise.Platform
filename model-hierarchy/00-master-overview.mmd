  ROOT(["Enterprise Platform — TS Models"]):::domain

  subgraph CORE [" Core Foundation "]
    direction TB
    BaseEntity[BaseEntity]:::sub
    EntityDataState["EntityDataState&lt;T&gt;"]:::sub
    RouteMetadata[RouteMetadata]:::sub
    Auth[CurrentUser + EffectivePermissions]:::sub
  end

  subgraph API [" API Contracts "]
    direction TB
    PagedResponse["PagedResponse&lt;T&gt;"]:::sub
    ApiResponse["ApiResponse&lt;T&gt;"]:::sub
    ApiError[ApiError]:::sub
    QueryParams[QueryParams + SortConfig]:::sub
  end

  subgraph CHROME [" Chrome (Layout) "]
    direction TB
    ChromeConfig[ChromeConfig]:::sub
    NavbarConfig[NavbarConfig]:::sub
    FooterConfig[FooterConfig]:::sub
    LoginPageConfig[LoginPageConfig]:::sub
    SubNav[BreadcrumbItem + PageHeaderConfig]:::sub
    Events[Nav events + NavNotification]:::sub
  end

  subgraph DPH [" DPH UI Kit "]
    direction TB
    Forms[FormSchema + SchemaField + SchemaFormEvent]:::sub
    DataTable["TableConfig&lt;T&gt; + ColumnDef&lt;T&gt;"]:::sub
    Wizard[StepsConfig + StepDescriptor]:::sub
    Components[Dialog/Drawer/Panel/Menu/Tree/...]:::sub
    Chart[ChartWidgetConfig + ChartWidgetDataset]:::sub
  end

  subgraph FEATURES [" Feature DTOs "]
    direction TB
    Users[UserDto + ListUsersResponse + Create/Rename/...]:::sub
  end

  ROOT --> CORE
  ROOT --> API
  ROOT --> CHROME
  ROOT --> DPH
  ROOT --> FEATURES

  BaseEntity -.->|"extends&nbsp;via&nbsp;feature&nbsp;types"| Users
