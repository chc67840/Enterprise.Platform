{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ],
    "AllowCredentials": true
  },
  "Bff": {
    "Proxy": {
      "ApiBaseUri": "http://localhost:5099/",
      "Timeout": "00:00:30",
      "AttachBearerToken": false
    }
  },
  "Observability": {
    "ServiceName": "enterprise-platform-web-ui",
    "ServiceVersion": "0.0.0-dev",
    "SamplingRatio": 1.0
  }
}
