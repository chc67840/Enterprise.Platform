/*
 * Root TypeScript configuration for the Angular client.
 *
 * Every strictness flag is intentional — see `Docs/Architecture/UI-Architecture.md`
 * Part I (principles) and Part X (developer experience). Relaxing any of these
 * without updating the architecture doc is a defect.
 *
 * Path aliases mirror the tier model (core / shared / features / layouts / config /
 * environments). Deep-path imports across tiers are disallowed by a future ESLint
 * rule (Phase 1.6); for now they are discouraged by convention.
 */
{
  "compileOnSave": false,
  "compilerOptions": {
    /* Base */
    "baseUrl": "./",
    "target": "ES2022",
    "module": "preserve",
    "lib": ["ES2022", "dom"],
    "importHelpers": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,

    /* Strictness — all enabled */
    "strict": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,

    /* Path aliases — tier model */
    "paths": {
      "@core/*":      ["src/app/core/*"],
      "@shared/*":    ["src/app/shared/*"],
      "@features/*":  ["src/app/features/*"],
      "@layouts/*":   ["src/app/layouts/*"],
      "@config/*":    ["src/app/config/*"],
      "@models/*":    ["src/app/core/models/*"],
      "@env/*":       ["src/environments/*"],
      "@utils":       ["src/app/shared/utils"],
      "@utils/*":     ["src/app/shared/utils/*"],
      "@constants":   ["src/app/shared/constants"],
      "@constants/*": ["src/app/shared/constants/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictTemplates": true,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "extendedDiagnostics": {
      "checks": {
        "invalidBananaInBox": "error",
        "missingControlFlowDirective": "error",
        "textAttributeNotBinding": "error",
        "nullishCoalescingNotNullable": "warning"
      }
    }
  },
  /*
   * NO `files` / `include` / `references` keys.
   *
   * This config is a BASE for `tsconfig.app.json` + `tsconfig.spec.json`
   * to extend. It is not meant to be invoked directly — Angular CLI
   * compiles each child tsconfig (ng build → tsconfig.app.json; vitest
   * → tsconfig.spec.json) and the IDE language service reads all three
   * for IntelliSense. The toolchain never runs `tsc -p tsconfig.json`.
   *
   * If you DO run `tsc -p tsconfig.json` directly, TypeScript falls back
   * to compiling every .ts file under cwd with the base types only — that
   * surfaces spurious "Cannot find name 'afterEach'" errors on spec files
   * because Vitest globals aren't loaded. We can't suppress that without
   * tripping TS18002 (`files: []`) or TS18003 (`include: []`) — the type
   * system requires SOMETHING to compile when invoked. So just don't
   * invoke this config directly. Use the children.
   *
   * NOTE — no `references` block either.
   *
   * Angular CLI compiles each tsconfig directly (`@angular/build` invokes
   * tsconfig.app.json for `ng build` / `ng serve`; `@angular/build:unit-test`
   * + Vitest invoke tsconfig.spec.json for tests). Project-references mode
   * (`tsc --build`) is NOT part of the Angular toolchain.
   *
   * If we add a `references` block here, TypeScript's language service
   * (used by VS Code / WebStorm) puts the workspace into project-references
   * mode and emits TS6306 ("Referenced project must have setting
   * 'composite: true'") on each child config. Adding `composite: true` then
   * forces declaration emission into out-tsc/ that no Angular tool actually
   * consumes — pure noise for zero benefit.
   *
   * Removing the block keeps the IDE quiet without changing what
   * `ng build` / `vitest` do. See Docs/Architecture/UI-Tsconfig-Reference.md
   * for the full rationale + revival recipe if a future tool needs project
   * references.
   */
}
