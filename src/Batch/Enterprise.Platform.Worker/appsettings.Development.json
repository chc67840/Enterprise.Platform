{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "AppDb": "Data Source=localhost;Initial Catalog=EnterprisePlatform;Integrated Security=True;Persist Security Info=False;Pooling=False;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Application Name=Enterprise.Platform.Worker;Command Timeout=0"
  },
  "DatabaseSettings": {
    "DefaultConnection": "App",
    "Connections": {
      "App": {
        "ConnectionStringName": "AppDb",
        "Provider": "SqlServer",
        "CommandTimeoutSeconds": 0,
        "IsReadReplica": false,
        "EnableSensitiveDataLogging": false,
        "EnableDetailedErrors": true
      }
    }
  },
  "Cache": {
    "Provider": "InMemory",
    "KeyPrefix": "ep",
    "DefaultTtl": "00:05:00"
  },
  "Observability": {
    "ServiceName": "enterprise-platform-worker",
    "ServiceVersion": "0.0.0-dev",
    "SamplingRatio": 1.0
  }
}
